# ── Credentials ──────────────────────────────────────────────────────────────
.env
*.env.local

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.conda/

# ── Processed data (generated by pipeline.py — do not commit) ─────────────────
# Large/binary outputs stay out of git. The two CSV files below are the
# exception: they are small, human-readable, and REQUIRED by the Streamlit app
# on Streamlit Community Cloud (which has no way to run the pipeline).
data/processed/
!data/processed/cluster_report.csv
!data/processed/cluster_representatives.csv

# Raw source CSVs — too large for GitHub (obtain from Kaggle, see data/raw/README.md)
data/raw/*.csv
data/raw/*.json

# ── Parquet files (anywhere in the repo) ──────────────────────────────────────
# Parquet outputs are binary blobs that diff poorly and can exceed GitHub limits.
*.parquet

# ── Models (large binary files) ───────────────────────────────────────────────
models/*.pkl
models/*.joblib
models/*.pt

# ── Sentence-BERT / HuggingFace cache ────────────────────────────────────────
.cache/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db